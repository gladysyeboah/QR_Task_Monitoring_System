@{
    ViewData["Title"] = "Workers Directory";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h3 mb-0 text-dark fw-bold">Workers Directory</h1>
        <p class="text-muted mb-0">Manage field staff, view performance, and assign roles.</p>
    </div>
    <div>
        <button class="btn btn-mono">
            <i class="bi bi-person-plus me-2"></i> Add New Worker
        </button>
    </div>
</div>

<!-- Search Panel -->
<div class="card-mono mb-4">
    <div class="row g-3">
        <div class="col-12 col-md-8">
            <input type="text" class="form-control-mono" placeholder="Search workers by name, email, specialization..." />
        </div>
        <div class="col-12 col-sm-6 col-md-3">
            <select class="form-control-mono">
                <option value="">All Statuses</option>
                <option value="active">Active Now</option>
                <option value="inactive">Offline</option>
            </select>
        </div>
        <div class="col-12 col-sm-6 col-md-1">
            <button class="btn btn-mono-outline w-100">Filter</button>
        </div>
    </div>
</div>

<!-- Workers Directory Grid -->
<div class="row g-4">
    <!-- Worker Card 1 -->
    <div class="col-12 col-md-6 col-xl-4">
        <div class="card-mono d-flex flex-column h-100 justify-content-between">
            <div>
                <div class="d-flex align-items-center mb-3">
                    <div class="bg-dark text-white rounded-circle d-flex align-items-center justify-content-center fw-bold fs-5 me-3" style="width: 48px; height: 48px;">
                        JD
                    </div>
                    <div>
                        <h5 class="fw-bold mb-0 text-dark">John Doe</h5>
                        <small class="text-muted">Lead Inspector</small>
                    </div>
                    <span class="badge-mono-dark ms-auto">Active</span>
                </div>
                <div class="mb-3 small">
                    <div class="d-flex justify-content-between mb-1">
                        <span class="text-muted">Email:</span>
                        <span class="text-dark">john.doe@qrfield.com</span>
                    </div>
                    <div class="d-flex justify-content-between mb-1">
                        <span class="text-muted">Active Tasks:</span>
                        <span class="text-dark fw-medium">3 Pending</span>
                    </div>
                    <div class="d-flex justify-content-between">
                        <span class="text-muted">Total Scans:</span>
                        <span class="text-dark fw-medium">112 Scans</span>
                    </div>
                </div>
            </div>
            <div class="d-flex gap-2">
                <button class="btn btn-sm btn-mono-outline flex-grow-1">View Profile</button>
                <button class="btn btn-sm btn-mono flex-grow-1">Assign Task</button>
            </div>
        </div>
    </div>
</div>
