@using Microsoft.AspNetCore.Identity
@using QR_Field_Monitoring_System.Models

@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

<ul class="navbar-nav align-items-center flex-row">
    @if (SignInManager.IsSignedIn(User))
    {
        <li class="nav-item me-3">
            <a class="nav-link text-white d-flex align-items-center"
               asp-area="Identity"
               asp-page="/Account/Manage/Index"
               title="Manage">
                <i class="bi bi-person-circle me-1 fs-5"></i>
                <span class="d-none d-md-inline">Hello @(User.Identity?.Name ?? "User")!</span>
            </a>
        </li>

        <li class="nav-item">
            <form class="form-inline"
                  asp-area="Identity"
                  asp-page="/Account/Logout"
                  asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">

                <button type="submit"
                        class="btn btn-outline-light btn-sm px-3 font-weight-500">
                    Logout
                </button>

            </form>
        </li>
    }
    else
    {
        <li class="nav-item me-2">
            <a class="btn btn-outline-light btn-sm px-3 font-weight-500"
               asp-area="Identity"
               asp-page="/Account/Register">
                Register
            </a>
        </li>

        <li class="nav-item">
            <a class="btn btn-light btn-sm px-3 font-weight-500"
               asp-area="Identity"
               asp-page="/Account/Login">
                Login
            </a>
        </li>
    }
</ul>