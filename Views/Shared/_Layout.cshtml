<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - QR Field Monitor</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/QR_Field_Monitoring_System.styles.css" asp-append-version="true" />
</head>
<body>
    <div id="app-wrapper">
        <!-- Top Navigation Bar -->
        <header class="navbar navbar-expand-lg top-navbar sticky-top">
            <div class="container-fluid px-3 d-flex align-items-center justify-content-between">
                <div class="d-flex align-items-center">
                    <button id="sidebarToggle" class="me-2" type="button" aria-label="Toggle Sidebar">
                        <i class="bi bi-list"></i>
                    </button>
                    <a class="navbar-brand d-flex align-items-center" asp-area="" asp-controller="Home" asp-action="Index">
                        <i class="bi bi-qr-code-scan me-2 text-white"></i>
                        <span>QR Field Monitor</span>
                    </a>
                </div>
                <div>
                    <partial name="_LoginPartial" />
                </div>
            </div>
        </header>

        <div class="d-flex flex-grow-1 position-relative">
            <!-- Sidebar backdrop for mobile viewports -->
            <div id="sidebarBackdrop" class="sidebar-backdrop"></div>

            <!-- Left Sidebar Navigation -->
            <aside class="sidebar">
                <nav class="nav flex-column py-3 flex-grow-1">
                    <a class="nav-link-custom @(ViewContext.RouteData.Values["controller"]?.ToString() == "Dashboard" ? "active" : "")" asp-area="" asp-controller="Dashboard" asp-action="Index">
                        <i class="bi bi-speedometer2"></i>
                        <span>Dashboard</span>
                    </a>
                    <a class="nav-link-custom @(ViewContext.RouteData.Values["controller"]?.ToString() == "Tasks" ? "active" : "")" asp-area="" asp-controller="Tasks" asp-action="Index">
                        <i class="bi bi-clipboard-check"></i>
                        <span>Tasks</span>
                    </a>
                    <a class="nav-link-custom @(ViewContext.RouteData.Values["controller"]?.ToString() == "Workers" ? "active" : "")" asp-area="" asp-controller="Workers" asp-action="Index">
                        <i class="bi bi-people"></i>
                        <span>Workers</span>
                    </a>
                    <a class="nav-link-custom @(ViewContext.RouteData.Values["controller"]?.ToString() == "Reports" ? "active" : "")" asp-area="" asp-controller="Reports" asp-action="Index">
                        <i class="bi bi-bar-chart-line"></i>
                        <span>Reports</span>
                    </a>
                    <a class="nav-link-custom @(ViewContext.RouteData.Values["controller"]?.ToString() == "Settings" ? "active" : "")" asp-area="" asp-controller="Settings" asp-action="Index">
                        <i class="bi bi-gear"></i>
                        <span>Settings</span>
                    </a>
                </nav>
                <div class="mt-auto px-4 py-3 border-top border-secondary text-center" style="border-color: #27272a !important;">
                    <small style="color: #71717a;">&copy; 2026 QR Field Monitor</small>
                </div>
            </aside>

            <!-- Main Scrollable Content Viewport -->
            <main class="main-content">
                <div class="container-fluid p-0">
                    @RenderBody()
                </div>
            </main>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
