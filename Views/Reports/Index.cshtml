@{
    ViewData["Title"] = "Reports & Analytics";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h3 mb-0 text-dark fw-bold">Reports &amp; Analytics</h1>
        <p class="text-muted mb-0">Export data logs, analyze scan frequencies, and track performance.</p>
    </div>
    <div>
        <button class="btn btn-mono">
            <i class="bi bi-download me-2"></i> Export CSV
        </button>
    </div>
</div>

<!-- Controls Panel -->
<div class="card-mono mb-4">
    <div class="row g-3">
        <div class="col-12 col-sm-6 col-md-4">
            <label class="form-label small fw-bold text-dark">Start Date</label>
            <input type="date" class="form-control-mono" value="2026-06-27" />
        </div>
        <div class="col-12 col-sm-6 col-md-4">
            <label class="form-label small fw-bold text-dark">End Date</label>
            <input type="date" class="form-control-mono" value="2026-07-04" />
        </div>
        <div class="col-12 col-md-4 d-flex align-items-end">
            <button class="btn btn-mono-outline w-100 py-2">
                <i class="bi bi-funnel me-2"></i> Apply Range
            </button>
        </div>
    </div>
</div>

<!-- Charts & Metrics Grid -->
<div class="row g-4 mb-4">
    <!-- Bar Chart Visual Mockup -->
    <div class="col-12 col-lg-8">
        <div class="card-mono h-100">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h5 class="fw-bold mb-0 text-dark">Scan Submissions (Last 7 Days)</h5>
                <span class="small text-muted">Weekly total: 312 scans</span>
            </div>
            
            <!-- Custom CSS styled Mock Bar Chart -->
            <div class="d-flex align-items-end justify-content-between pt-4 px-2" style="height: 220px; border-bottom: 2px solid var(--border-color);">
                <div class="d-flex flex-column align-items-center flex-grow-1">
                    <div class="bg-dark w-50" style="height: 120px; border-radius: 4px 4px 0 0;" title="Mon: 40 scans"></div>
                    <span class="small text-muted mt-2">Mon</span>
                </div>
                <div class="d-flex flex-column align-items-center flex-grow-1">
                    <div class="bg-dark w-50" style="height: 150px; border-radius: 4px 4px 0 0;" title="Tue: 50 scans"></div>
                    <span class="small text-muted mt-2">Tue</span>
                </div>
                <div class="d-flex flex-column align-items-center flex-grow-1">
                    <div class="bg-dark w-50" style="height: 90px; border-radius: 4px 4px 0 0;" title="Wed: 30 scans"></div>
                    <span class="small text-muted mt-2">Wed</span>
                </div>
                <div class="d-flex flex-column align-items-center flex-grow-1">
                    <div class="bg-dark w-50" style="height: 180px; border-radius: 4px 4px 0 0;" title="Thu: 60 scans"></div>
                    <span class="small text-muted mt-2">Thu</span>
                </div>
                <div class="d-flex flex-column align-items-center flex-grow-1">
                    <div class="bg-dark w-50" style="height: 110px; border-radius: 4px 4px 0 0;" title="Fri: 37 scans"></div>
                    <span class="small text-muted mt-2">Fri</span>
                </div>
                <div class="d-flex flex-column align-items-center flex-grow-1">
                    <div class="bg-secondary w-50" style="height: 45px; border-radius: 4px 4px 0 0;" title="Sat: 15 scans" style="opacity: 0.5;"></div>
                    <span class="small text-muted mt-2">Sat</span>
                </div>
                <div class="d-flex flex-column align-items-center flex-grow-1">
                    <div class="bg-secondary w-50" style="height: 30px; border-radius: 4px 4px 0 0;" title="Sun: 10 scans" style="opacity: 0.5;"></div>
                    <span class="small text-muted mt-2">Sun</span>
                </div>
            </div>
        </div>
    </div>

    <!-- Productivity Metrics -->
    <div class="col-12 col-lg-4">
        <div class="card-mono h-100">
            <h5 class="fw-bold mb-3 text-dark">Efficiency Breakdown</h5>
            <div class="list-group list-group-flush">
                <div class="list-group-item bg-transparent px-0 py-3 border-bottom d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="mb-0 fw-semibold text-dark">Average Scan Verification</h6>
                        <small class="text-muted">Time from assignment to submission</small>
                    </div>
                    <span class="fw-bold fs-5 text-dark">4.2h</span>
                </div>
                <div class="list-group-item bg-transparent px-0 py-3 border-bottom d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="mb-0 fw-semibold text-dark">Scan Confirmed Rate</h6>
                        <small class="text-muted">Total scans matching target GPS</small>
                    </div>
                    <span class="fw-bold fs-5 text-dark">98.4%</span>
                </div>
                <div class="list-group-item bg-transparent px-0 py-3 border-0 d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="mb-0 fw-semibold text-dark">Missed Inspections</h6>
                        <small class="text-muted">Unresolved tasks past deadline</small>
                    </div>
                    <span class="fw-bold fs-5 text-dark">3</span>
                </div>
            </div>
        </div>
    </div>
</div>
