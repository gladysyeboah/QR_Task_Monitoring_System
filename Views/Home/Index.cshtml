@{
    ViewData["Title"] = "Home";
}

<div class="card-mono text-center py-5 my-4">
    <i class="bi bi-qr-code-scan display-1 text-dark mb-4"></i>
    <h1 class="display-5 fw-bold text-dark mb-3">QR Field Monitoring System</h1>
    <p class="lead text-muted mx-auto mb-4" style="max-width: 600px;">
        A high-performance field operations management platform. Track task progress, verify scan check-ins, and manage field worker directories.
    </p>
    <div class="d-flex justify-content-center gap-3 flex-wrap">
        <a class="btn btn-mono px-4 py-2" asp-controller="Dashboard" asp-action="Index">
            <i class="bi bi-speedometer2 me-2"></i> Go to Dashboard
        </a>
        <a class="btn btn-mono-outline px-4 py-2" asp-controller="Tasks" asp-action="Index">
            <i class="bi bi-clipboard-check me-2"></i> View Active Tasks
        </a>
    </div>
</div>
