@model QR_Field_Monitoring_System.Models.FieldTask
@{
    ViewData["Title"] = "Delete Task";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h3 mb-0 text-dark fw-bold">Delete Task</h1>
        <p class="text-muted mb-0">Are you sure you want to permanently delete this task?</p>
    </div>
    <div>
        <a class="btn btn-mono-outline" asp-action="Index">
            <i class="bi bi-arrow-left me-2"></i> Back
        </a>
    </div>
</div>

<div class="row">
    <div class="col-12 col-lg-6">
        <div class="card-mono border-dark">
            <div class="d-flex align-items-center text-dark mb-3">
                <i class="bi bi-exclamation-triangle-fill fs-4 me-2"></i>
                <h5 class="fw-bold mb-0">Warning: Permanent Action</h5>
            </div>
            
            <p class="text-muted small">
                Deleting this task will permanently remove it and all associated submissions/reports from the system database. This action cannot be undone.
            </p>

            <div class="bg-light border rounded p-3 mb-4">
                <table class="table table-sm table-mono mb-0 bg-transparent">
                    <tbody>
                        <tr>
                            <td class="fw-bold text-dark border-0" style="width: 120px;">Task Title:</td>
                            <td class="text-muted border-0">@Model.Title</td>
                        </tr>
                        <tr>
                            <td class="fw-bold text-dark border-0">Asset Name:</td>
                            <td class="text-muted border-0">@Model.AssetName</td>
                        </tr>
                        <tr>
                            <td class="fw-bold text-dark border-0">Location:</td>
                            <td class="text-muted border-0">@Model.Location</td>
                        </tr>
                        <tr>
                            <td class="fw-bold text-dark border-0">Assigned To:</td>
                            <td class="text-muted border-0">@(Model.AssignedWorker?.FullName ?? Model.AssignedWorker?.UserName ?? "Unassigned")</td>
                        </tr>
                    </tbody>
                </table>
            </div>

            <form asp-action="Delete" method="post">
                <input type="hidden" asp-for="Id" />
                <div class="d-flex justify-content-end gap-2">
                    <a class="btn btn-mono-outline" asp-action="Index">Cancel</a>
                    <button type="submit" class="btn btn-mono">Confirm Delete</button>
                </div>
            </form>
        </div>
    </div>
</div>
