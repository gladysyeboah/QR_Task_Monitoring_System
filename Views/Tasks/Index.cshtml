@{
    ViewData["Title"] = "Tasks Management";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h3 mb-0 text-dark fw-bold">Tasks Management</h1>
        <p class="text-muted mb-0">Create, assign, and track field monitoring tasks.</p>
    </div>
    <div>
        <button class="btn btn-mono">
            <i class="bi bi-plus-lg me-2"></i> Create New Task
        </button>
    </div>
</div>

<!-- Search & Filter Panel -->
<div class="card-mono mb-4">
    <div class="row g-3">
        <div class="col-12 col-md-5">
            <label class="form-label small fw-bold text-dark">Search Tasks</label>
            <div class="input-group">
                <span class="input-group-text bg-light border-end-0 text-muted" style="border: 1px solid var(--border-color);"><i class="bi bi-search"></i></span>
                <input type="text" class="form-control-mono ps-2 border-start-0" placeholder="Search by name, code or worker..." />
            </div>
        </div>
        <div class="col-12 col-sm-6 col-md-3">
            <label class="form-label small fw-bold text-dark">Status</label>
            <select class="form-control-mono">
                <option value="">All Statuses</option>
                <option value="pending">Pending</option>
                <option value="in-progress">In Progress</option>
                <option value="completed">Completed</option>
            </select>
        </div>
        <div class="col-12 col-sm-6 col-md-3">
            <label class="form-label small fw-bold text-dark">Priority</label>
            <select class="form-control-mono">
                <option value="">All Priorities</option>
                <option value="low">Low</option>
                <option value="medium">Medium</option>
                <option value="high">High</option>
            </select>
        </div>
        <div class="col-12 col-md-1 d-flex align-items-end">
            <button class="btn btn-mono-outline w-100 py-2" title="Reset Filters">
                <i class="bi bi-arrow-counterclockwise"></i>
            </button>
        </div>
    </div>
</div>

<!-- Datatable Card -->
<div class="card-mono">
    <div class="table-responsive">
        <table class="table table-hover table-mono mb-0">
            <thead>
                <tr>
                    <th style="width: 100px;">Task ID</th>
                    <th>Task Name</th>
                    <th>Assigned Worker</th>
                    <th>Priority</th>
                    <th>Status</th>
                    <th>Last Scan</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td class="fw-bold">#TSK-1092</td>
                    <td class="fw-medium">Site Inspections (Building A)</td>
                    <td>John Doe</td>
                    <td><span class="badge-mono">Medium</span></td>
                    <td><span class="badge-mono-dark">Scanned</span></td>
                    <td class="text-muted small">2026-07-04 03:12</td>
                    <td class="text-end">
                        <button class="btn btn-sm btn-mono-outline me-1" title="Generate QR"><i class="bi bi-qr-code"></i></button>
                        <button class="btn btn-sm btn-mono" title="Edit"><i class="bi bi-pencil"></i></button>
                    </td>
                </tr>
            </tbody>
        </table>
    </div>

    <!-- Pagination -->
    <div class="d-flex justify-content-between align-items-center mt-4 pt-3 border-top border-light">
        <span class="small text-muted">Showing 1 of 1 tasks</span>
        <nav aria-label="Page navigation">
            <ul class="pagination pagination-sm mb-0">
                <li class="page-item disabled"><a class="page-link border-light text-dark bg-white" href="#">Previous</a></li>
                <li class="page-item active"><a class="page-link border-dark bg-dark text-white" href="#">1</a></li>
                <li class="page-item disabled"><a class="page-link border-light text-dark bg-white" href="#">Next</a></li>
            </ul>
        </nav>
    </div>
</div>
