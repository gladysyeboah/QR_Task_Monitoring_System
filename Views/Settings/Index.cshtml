@{
    ViewData["Title"] = "System Settings";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h3 mb-0 text-dark fw-bold">System Settings</h1>
        <p class="text-muted mb-0">Configure QR scan intervals, timeouts, boundaries, and system preferences.</p>
    </div>
    <div>
        <button class="btn btn-mono">
            <i class="bi bi-check-lg me-2"></i> Save All Changes
        </button>
    </div>
</div>

<div class="row g-4">
    <!-- QR Scan & Field Rules Configurations -->
    <div class="col-12 col-lg-7">
        <div class="card-mono mb-4">
            <h5 class="fw-bold mb-4 text-dark"><i class="bi bi-qr-code-scan me-2"></i> QR Field Rules Config</h5>
            <div class="row g-3">
                <div class="col-12 col-md-6">
                    <label class="form-label small fw-bold text-dark">Default Scan Validation Range (Meters)</label>
                    <input type="number" class="form-control-mono" value="50" />
                    <div class="form-text small text-muted">Geofenced radius for worker to verify QR check-ins.</div>
                </div>
                <div class="col-12 col-md-6">
                    <label class="form-label small fw-bold text-dark">GPS Precision Required</label>
                    <select class="form-control-mono">
                        <option value="high">High (Within 5m)</option>
                        <option value="medium" selected>Medium (Within 15m)</option>
                        <option value="low">Low (Any GPS Lock)</option>
                    </select>
                    <div class="form-text small text-muted">Maximum allowed uncertainty in device geolocation.</div>
                </div>
                <div class="col-12 col-md-6">
                    <label class="form-label small fw-bold text-dark">QR Scan Verification Expiry (Hours)</label>
                    <input type="number" class="form-control-mono" value="24" />
                    <div class="form-text small text-muted">Hours a QR code remains valid after generation.</div>
                </div>
                <div class="col-12 col-md-6">
                    <label class="form-label small fw-bold text-dark">Image Verification</label>
                    <div class="form-check form-switch mt-2">
                        <input class="form-check-input" type="checkbox" role="switch" id="imageVerifySwitch" checked>
                        <label class="form-check-label small text-muted" for="imageVerifySwitch">Require photo capture with scan submission</label>
                    </div>
                </div>
            </div>
        </div>

        <div class="card-mono">
            <h5 class="fw-bold mb-4 text-dark"><i class="bi bi-shield-lock me-2"></i> Role-Based Permissions</h5>
            <div class="table-responsive">
                <table class="table table-mono mb-0 align-middle">
                    <thead>
                        <tr>
                            <th>Module</th>
                            <th>Worker Role</th>
                            <th>Admin Role</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td class="fw-medium">View Dashboard</td>
                            <td><i class="bi bi-x-circle text-muted"></i> Disabled</td>
                            <td><i class="bi bi-check-circle-fill text-dark"></i> Active</td>
                        </tr>
                        <tr>
                            <td class="fw-medium">Submit QR Scans</td>
                            <td><i class="bi bi-check-circle-fill text-dark"></i> Active</td>
                            <td><i class="bi bi-check-circle-fill text-dark"></i> Active</td>
                        </tr>
                        <tr>
                            <td class="fw-medium">Manage Task List</td>
                            <td><i class="bi bi-x-circle text-muted"></i> Disabled</td>
                            <td><i class="bi bi-check-circle-fill text-dark"></i> Active</td>
                        </tr>
                        <tr>
                            <td class="fw-medium">Edit App Configurations</td>
                            <td><i class="bi bi-x-circle text-muted"></i> Disabled</td>
                            <td><i class="bi bi-check-circle-fill text-dark"></i> Active</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Preferences & Account Details -->
    <div class="col-12 col-lg-5">
        <div class="card-mono mb-4">
            <h5 class="fw-bold mb-4 text-dark"><i class="bi bi-bell me-2"></i> Notification Preferences</h5>
            <div class="mb-3">
                <div class="form-check mb-2">
                    <input class="form-check-input" type="checkbox" id="emailReportCheck" checked>
                    <label class="form-check-label small text-dark" for="emailReportCheck">
                        Email daily field activity summaries
                    </label>
                </div>
                <div class="form-check mb-2">
                    <input class="form-check-input" type="checkbox" id="alertSmsCheck">
                    <label class="form-check-label small text-dark" for="alertSmsCheck">
                        SMS alerts on missed scan deadlines
                    </label>
                </div>
                <div class="form-check">
                    <input class="form-check-input" type="checkbox" id="systemFailCheck" checked>
                    <label class="form-check-label small text-dark" for="systemFailCheck">
                        Notify on database synchronization failures
                    </label>
                </div>
            </div>
        </div>

        <div class="card-mono">
            <h5 class="fw-bold mb-4 text-dark"><i class="bi bi-sliders me-2"></i> System Theme Preferences</h5>
            <div class="mb-3">
                <label class="form-label small fw-bold text-dark">Active Interface Theme</label>
                <div class="d-flex flex-column gap-2 mt-1">
                    <div class="form-check">
                        <input class="form-check-input" type="radio" name="themeRadio" id="themeRadioMono" checked>
                        <label class="form-check-label small text-dark" for="themeRadioMono">
                            Grayscale/Monochrome (High Contrast B&amp;W)
                        </label>
                    </div>
                    <div class="form-check">
                        <input class="form-check-input" type="radio" name="themeRadio" id="themeRadioSaaS" disabled>
                        <label class="form-check-label small text-muted" for="themeRadioSaaS">
                            Premium SaaS (Dark Slate / Teal - Coming Soon)
                        </label>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
