@model QR_Field_Monitoring_System.ViewModels.DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h3 mb-0 text-dark fw-bold">Dashboard Overview</h1>
        <p class="text-muted mb-0">Real-time status of tasks and workers in the field.</p>
    </div>
    <div>
        <button class="btn btn-mono" onclick="window.location.reload();">
            <i class="bi bi-arrow-repeat me-2"></i> Refresh Data
        </button>
    </div>
</div>

<!-- Stats Grid -->
<div class="row g-4 mb-4">
    <div class="col-12 col-sm-6 col-xl-3">
        <div class="card-mono d-flex align-items-center">
            <div class="rounded-circle bg-dark text-white d-flex align-items-center justify-content-center me-3" style="width: 48px; height: 48px;">
                <i class="bi bi-journal-text fs-5"></i>
            </div>
            <div>
                <span class="d-block text-muted small fw-medium">Total Tasks</span>
                <span class="h3 mb-0 fw-bold">@Model.TotalTasks</span>
            </div>
        </div>
    </div>
    <div class="col-12 col-sm-6 col-xl-3">
        <div class="card-mono d-flex align-items-center">
            <div class="rounded-circle bg-dark text-white d-flex align-items-center justify-content-center me-3" style="width: 48px; height: 48px;">
                <i class="bi bi-clock-history fs-5"></i>
            </div>
            <div>
                <span class="d-block text-muted small fw-medium">Pending Tasks</span>
                <span class="h3 mb-0 fw-bold">@Model.PendingTasks</span>
            </div>
        </div>
    </div>
    <div class="col-12 col-sm-6 col-xl-3">
        <div class="card-mono d-flex align-items-center">
            <div class="rounded-circle bg-dark text-white d-flex align-items-center justify-content-center me-3" style="width: 48px; height: 48px;">
                <i class="bi bi-check-circle fs-5"></i>
            </div>
            <div>
                <span class="d-block text-muted small fw-medium">Completed Tasks</span>
                <span class="h3 mb-0 fw-bold">@Model.CompletedTasks</span>
            </div>
        </div>
    </div>
    <div class="col-12 col-sm-6 col-xl-3">
        <div class="card-mono d-flex align-items-center">
            <div class="rounded-circle bg-dark text-white d-flex align-items-center justify-content-center me-3" style="width: 48px; height: 48px;">
                <i class="bi bi-people fs-5"></i>
            </div>
            <div>
                <span class="d-block text-muted small fw-medium">Active Workers</span>
                <span class="h3 mb-0 fw-bold">@Model.ActiveWorkersCount / @Model.TotalWorkersCount</span>
            </div>
        </div>
    </div>
</div>

<!-- Extra Premium Skeletons -->
<div class="row g-4">
    <!-- Recent Activity -->
    <div class="col-12 col-lg-8">
        <div class="card-mono h-100">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h5 class="fw-bold mb-0 text-dark">Recent Activity Feed</h5>
                <a class="btn btn-sm btn-mono-outline" asp-controller="Reports" asp-action="Index">View Detailed Report</a>
            </div>
            <div class="table-responsive">
                <table class="table table-hover table-mono mb-0">
                    <thead>
                        <tr>
                            <th>Task</th>
                            <th>Worker</th>
                            <th>Condition</th>
                            <th>Timestamp</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (!Model.LatestSubmissions.Any())
                        {
                            <tr>
                                <td colspan="4" class="text-center py-4 text-muted">No recent submissions found.</td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var submission in Model.LatestSubmissions)
                            {
                                <tr>
                                    <td class="fw-medium">@(submission.FieldTask?.Title ?? "N/A")</td>
                                    <td>@(Model.WorkerNames.TryGetValue(submission.WorkerId, out var workerName) ? workerName : "Unknown")</td>
                                    <td>
                                        @if (submission.Condition == QR_Field_Monitoring_System.Models.Enums.ConditionStatus.Good)
                                        {
                                            <span class="badge-mono-dark">Good</span>
                                        }
                                        else if (submission.Condition == QR_Field_Monitoring_System.Models.Enums.ConditionStatus.Fair)
                                        {
                                            <span class="badge-mono">Fair</span>
                                        }
                                        else if (submission.Condition == QR_Field_Monitoring_System.Models.Enums.ConditionStatus.Faulty)
                                        {
                                            <span class="badge bg-dark text-white">Faulty</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-dark text-white">Damaged</span>
                                        }
                                    </td>
                                    <td class="text-muted small">@submission.SubmittedAt.ToString("g")</td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Right Column: Recently Created Tasks & Quick Actions -->
    <div class="col-12 col-lg-4">
        <!-- Quick Actions Card -->
        <div class="card-mono mb-4">
            <h5 class="fw-bold mb-3 text-dark">Quick Actions</h5>
            <div class="d-grid gap-2">
                <a class="btn btn-mono text-start d-flex justify-content-between align-items-center" asp-controller="Tasks" asp-action="Index">
                    <span>Create Task</span>
                    <i class="bi bi-plus-lg"></i>
                </a>
                <a class="btn btn-mono-outline text-start d-flex justify-content-between align-items-center" asp-controller="Tasks" asp-action="Index">
                    <span>Generate QR Codes</span>
                    <i class="bi bi-qr-code"></i>
                </a>
                <a class="btn btn-mono-outline text-start d-flex justify-content-between align-items-center" asp-controller="Reports" asp-action="Index">
                    <span>View Analytics</span>
                    <i class="bi bi-bar-chart-line"></i>
                </a>
            </div>
        </div>

        <!-- Recently Created Tasks Card -->
        <div class="card-mono">
            <h5 class="fw-bold mb-3 text-dark">Recently Created Tasks</h5>
            @if (!Model.RecentTasks.Any())
            {
                <p class="text-muted small mb-0">No tasks created yet.</p>
            }
            else
            {
                <div class="list-group list-group-flush">
                    @foreach (var task in Model.RecentTasks)
                    {
                        <div class="list-group-item bg-transparent px-0 py-2 border-bottom d-flex justify-content-between align-items-center">
                            <div>
                                <h6 class="mb-0 fw-semibold text-dark small">@task.Title</h6>
                                <small class="text-muted">Due: @task.DueDate.ToString("d")</small>
                            </div>
                            <span class="badge-mono">@task.Status</span>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
</div>
