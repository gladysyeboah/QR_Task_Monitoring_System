@{
    ViewData["Title"] = "Dashboard";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h3 mb-0 text-dark fw-bold">Dashboard Overview</h1>
        <p class="text-muted mb-0">Real-time status of tasks and workers in the field.</p>
    </div>
    <div>
        <button class="btn btn-mono">
            <i class="bi bi-arrow-repeat me-2"></i> Refresh Data
        </button>
    </div>
</div>

<!-- Stats Grid -->
<div class="row g-4 mb-4">
    <div class="col-12 col-sm-6 col-xl-3">
        <div class="card-mono d-flex align-items-center">
            <div class="rounded-circle bg-dark text-white d-flex align-items-center justify-content-center me-3" style="width: 48px; height: 48px;">
                <i class="bi bi-journal-text fs-5"></i>
            </div>
            <div>
                <span class="d-block text-muted small fw-medium">Total Tasks</span>
                <span class="h3 mb-0 fw-bold">1</span>
            </div>
        </div>
    </div>
    <div class="col-12 col-sm-6 col-xl-3">
        <div class="card-mono d-flex align-items-center">
            <div class="rounded-circle bg-dark text-white d-flex align-items-center justify-content-center me-3" style="width: 48px; height: 48px;">
                <i class="bi bi-clock-history fs-5"></i>
            </div>
            <div>
                <span class="d-block text-muted small fw-medium">Pending Tasks</span>
                <span class="h3 mb-0 fw-bold">0</span>
            </div>
        </div>
    </div>
    <div class="col-12 col-sm-6 col-xl-3">
        <div class="card-mono d-flex align-items-center">
            <div class="rounded-circle bg-dark text-white d-flex align-items-center justify-content-center me-3" style="width: 48px; height: 48px;">
                <i class="bi bi-check-circle fs-5"></i>
            </div>
            <div>
                <span class="d-block text-muted small fw-medium">Completed Tasks</span>
                <span class="h3 mb-0 fw-bold">1</span>
            </div>
        </div>
    </div>
    <div class="col-12 col-sm-6 col-xl-3">
        <div class="card-mono d-flex align-items-center">
            <div class="rounded-circle bg-dark text-white d-flex align-items-center justify-content-center me-3" style="width: 48px; height: 48px;">
                <i class="bi bi-people fs-5"></i>
            </div>
            <div>
                <span class="d-block text-muted small fw-medium">Active Workers</span>
                <span class="h3 mb-0 fw-bold">1 / 1</span>
            </div>
        </div>
    </div>
</div>

<!-- Extra Premium Skeletons -->
<div class="row g-4">
    <!-- Recent Activity -->
    <div class="col-12 col-lg-8">
        <div class="card-mono h-100">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h5 class="fw-bold mb-0 text-dark">Recent Activity Feed</h5>
                <a class="btn btn-sm btn-mono-outline" asp-controller="Reports" asp-action="Index">View Detailed Report</a>
            </div>
            <div class="table-responsive">
                <table class="table table-hover table-mono mb-0">
                    <thead>
                        <tr>
                            <th>Task</th>
                            <th>Worker</th>
                            <th>Status</th>
                            <th>Timestamp</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td class="fw-medium">Site Inspections (Building A)</td>
                            <td>John Doe</td>
                            <td><span class="badge-mono-dark">Scanned</span></td>
                            <td class="text-muted small">03:12 AM</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Active Field Alerts -->
    <div class="col-12 col-lg-4">
        <div class="card-mono h-100 d-flex flex-column">
            <h5 class="fw-bold mb-3 text-dark">Quick Stats Summary</h5>
            <div class="flex-grow-1 d-flex flex-column justify-content-center">
                <div class="mb-4">
                    <div class="d-flex justify-content-between mb-1">
                        <span class="text-muted small fw-medium">Overall Progress</span>
                        <span class="text-dark small fw-bold">66%</span>
                    </div>
                    <div class="progress bg-light" style="height: 8px; border: 1px solid var(--border-color);">
                        <div class="progress-bar bg-dark" role="progressbar" style="width: 66%;" aria-valuenow="66" aria-valuemin="0" aria-valuemax="100"></div>
                    </div>
                </div>

                <div class="mb-4">
                    <div class="d-flex justify-content-between mb-1">
                        <span class="text-muted small fw-medium">Active Worker Utilization</span>
                        <span class="text-dark small fw-bold">80%</span>
                    </div>
                    <div class="progress bg-light" style="height: 8px; border: 1px solid var(--border-color);">
                        <div class="progress-bar bg-dark" role="progressbar" style="width: 80%;" aria-valuenow="80" aria-valuemin="0" aria-valuemax="100"></div>
                    </div>
                </div>

                <div class="mb-2">
                    <div class="d-flex justify-content-between mb-1">
                        <span class="text-muted small fw-medium">QR Scanning Efficiency</span>
                        <span class="text-dark small fw-bold">95%</span>
                    </div>
                    <div class="progress bg-light" style="height: 8px; border: 1px solid var(--border-color);">
                        <div class="progress-bar bg-dark" role="progressbar" style="width: 95%;" aria-valuenow="95" aria-valuemin="0" aria-valuemax="100"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
